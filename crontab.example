# =============================================================================
# PE Research cron schedule
# =============================================================================
# 적용 방법:
#   1) setup.sh 실행 (자동 등록)
#   또는 수동:
#   2) crontab -e 후 아래 라인 추가
# =============================================================================

# 환경 변수 (cron은 기본 PATH가 매우 짧음)
PATH=/Users/aerok86/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
SHELL=/bin/bash

# 매일 (월-금) 오전 08:45 KST - PE Daily Research
# 업무 시작 9시 전 완료 목표. 평균 실행 시간 10-15분.
45 8 * * 1-5 "/Users/aerok86/Library/CloudStorage/OneDrive-공유라이브러리-Onedrive/07_Claude/pe-resarch/pe-research/scripts/daily-research.sh"

# =============================================================================
# cron field reference:
#   분  시  일  월  요일  명령
#   45   8   *   *   1-5  ...
#
# 요일: 0=일, 1=월, 2=화, 3=수, 4=목, 5=금, 6=토
# =============================================================================
